@page "/CrearTarea"
@using TareasApp.Services
@using TareaWeb.Tarea
@inject TareasService tareasService
@inject NavigationManager navigationManager

<div class="crear-container">

    <div class="crear-header">
        <h1>📝 Crear Nueva Tarea</h1>
        <p>Ingresa la descripción de tu nueva tarea</p>
    </div>

    <div class="crear-body">
        <div class="row align-items-center g-2">
            <div class="col-8">
                <input @bind="descripcion"
                       placeholder="¿Qué necesitas hacer?"
                       class="form-control input-custom" />
            </div>
            <div class="col-4 d-flex flex-row gap-2">
                <button class="btn btn-outline-secondary btn-icon"
                        @onclick="@(() => navigationManager.NavigateTo("/"))">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708" />
                    </svg>
                </button>
                <button class="btn btn-success btn-icon" @onclick="Guardar">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11 2H9v3h2z" />
                        <path d="M1.5 0h11.586a1.5 1.5 0 0 1 1.06.44l1.415 1.414A1.5 1.5 0 0 1 16 2.914V14.5a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 14.5v-13A1.5 1.5 0 0 1 1.5 0M1 1.5v13a.5.5 0 0 0 .5.5H2v-4.5A1.5 1.5 0 0 1 3.5 9h9a1.5 1.5 0 0 1 1.5 1.5V15h.5a.5.5 0 0 0 .5-.5V2.914a.5.5 0 0 0-.146-.353l-1.415-1.415A.5.5 0 0 0 13.086 1H13v4.5A1.5 1.5 0 0 1 11.5 7h-7A1.5 1.5 0 0 1 3 5.5V1H1.5a.5.5 0 0 0-.5.5m3 4a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 .5-.5V1H4zM3 15h10v-4.5a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5z" />
                    </svg>
                </button>
            </div>
        </div>
    </div>

</div>

<style>
    .crear-container {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(5, 39, 103, 0.12);
        max-width: 640px;
        margin: 3rem auto;
        overflow: hidden;
    }

    .crear-header {
        background: linear-gradient(180deg, rgb(5, 39, 103) 0%, #3a0647 70%);
        color: white;
        padding: 1.75rem 2rem;
    }

        .crear-header h1 {
            font-size: 1.5rem;
            font-weight: 700;
            margin: 0 0 0.25rem;
        }

        .crear-header p {
            margin: 0;
            opacity: 0.8;
            font-size: 0.9rem;
        }

    .crear-body {
        padding: 1.75rem 2rem;
    }

    .input-custom {
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        padding: 0.65rem 1rem;
        font-size: 1rem;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .input-custom:focus {
            border-color: rgb(5, 39, 103);
            box-shadow: 0 0 0 3px rgba(5, 39, 103, 0.1);
            outline: none;
        }

    .btn-icon {
        width: 42px;
        height: 42px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
    }
</style>

@code {

    string descripcion;

    void Guardar()
    {
        var nueva = new Tarea { Descripcion = descripcion };
        tareasService.Agregar(nueva);
        navigationManager.NavigateTo("/");
    }

}