@page "/"
@using TareasApp.Services
@using TareaWeb.Tarea
@inject TareasService tareasService
@inject NavigationManager navigationManager

<h3>Gestor de Tareas MAUI Blazor</h3>

<button class="btn btn-primary" @onclick="IrCrear">Crear Nueva Tarea</button>

<table class="table mt-3">
    <thead>
        <tr>
            <th>Id</th>
            <th>Descripción</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var tarea in tareas)
        {
            <tr>
                <td>@tarea.Id</td>
                <td>@tarea.Descripcion</td>
            </tr>
        }
    </tbody>
</table>

@code {

    List<Tarea> tareas = new();

    protected override async Task OnInitializedAsync()
    {
        tareas = tareasService.ObtenerTodas();
    }

    void IrCrear()
    {
        navigationManager.NavigateTo("/CrearTarea");
    }

}