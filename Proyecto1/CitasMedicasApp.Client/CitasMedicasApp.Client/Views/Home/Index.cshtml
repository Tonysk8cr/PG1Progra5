@{
    ViewData["Title"] = "Home Page";
}

<div class="row mt-4">

    <!--Menu utilizando card de bootstrap y utilizando los id para llenarse por JS-->
    <div class="col-md-3">
        <div class="card shadow border-0 text-center">
            <div class="card-body">
                <h5 class="text-muted">Pacientes</h5>
                <h2 class="text-primary" id="totalPacientes">0</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow border-0 text-center">
            <div class="card-body">
                <h5 class="text-muted">Doctores</h5>
                <h2 class="text-success" id="totalDoctores">0</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow border-0 text-center">
            <div class="card-body">
                <h5 class="text-muted">Especialidades</h5>
                <h2 class="text-warning" id="totalEspecialidades">0</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow border-0 text-center">
            <div class="card-body">
                <h5 class="text-muted">Citas Hoy</h5>
                <h2 class="text-danger" id="totalCitasHoy">0</h2>
            </div>
        </div>
    </div>
</div>
<!--Se llama al script de JS para el dashboard-->
@section Scripts {
    <script src="~/js/dashboard.js"></script>
}
