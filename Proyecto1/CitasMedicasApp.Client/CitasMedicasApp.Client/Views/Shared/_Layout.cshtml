<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CitasMedicasApp.Client</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CitasMedicasApp.Client.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>

    <div class="d-flex">

        <div class="bg-dark text-white p-3 vh-100" style="width:250px;">

            <h4 class="text-center mb-4">Menu</h4>

            <ul class="nav nav-pills flex-column mb-auto">

                <li class="nav-item mb-2">
                    <a asp-controller="Home" asp-action="Index" class="nav-link text-white">
                         Inicio
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a asp-controller="Pacientes" asp-action="Index" class="nav-link text-white">
                         Pacientes
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a asp-controller="Doctores" asp-action="Index" class="nav-link text-white">
                          Doctores
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a asp-controller="Especialidad" asp-action="Index" class="nav-link text-white">
                         Especialidades
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a asp-controller="Citas" asp-action="Index" class="nav-link text-white">
                         Citas
                    </a>
                </li>

            </ul>

        </div>

        
        <div class="flex-grow-1 p-4 bg-light">

            <header class="mb-4">
                <nav class="navbar navbar-light bg-white shadow-sm mb-3">
                    <span class="navbar-brand mb-0 h5">
                        Sistema de Gestión de Citas Médicas
                    </span>
                </nav>
            </header>

            <main>
                @RenderBody()
            </main>

        </div>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
