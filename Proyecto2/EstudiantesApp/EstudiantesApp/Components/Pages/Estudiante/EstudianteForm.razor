@inject NavigationManager navigationManager
@page "/estudiante/nuevo"
@page "/estudiante/editar/{Id:int}"
@using EstudiantesApp.Services
@using EstudiantesAppWeb.Estudiante
@inject EstudianteService estudianteService

<h3>@(Id > 0 ? "Editar Estudiante" : "Nuevo Estudiante")</h3>

<div class="row g-3">

    <div class="col-md-4">
        <label>Nombre</label>
        <input class="form-control" @bind="modelo.Nombre" />
    </div>

    <div class="col-md-4">
        <label>Primer Apellido</label>
        <input class="form-control" @bind="modelo.PrimerApellido" />
    </div>

    <div class="col-md-4">
        <label>Segundo Apellido</label>
        <input class="form-control" @bind="modelo.SegundoApellido" />
    </div>

    <div class="col-md-4">
        <label>Cédula</label>
        <input class="form-control" @bind="modelo.Cedula" />
    </div>

    <div class="col-md-4">
        <label>Correo</label>
        <input class="form-control" @bind="modelo.Correo" />
    </div>
   
    <!-- TODO: Modificar para que solo permita numeros-->
    <div class="col-md-4">
        <label>Teléfono</label>
        <input class="form-control" @bind="modelo.Telefono" /> 
    </div>

    <div class="col-md-4">
        <label>Fecha de Nacimiento</label>
        <input type="date" class="form-control" @bind="modelo.FechaNacimiento" />
    </div>

    <div class="col-md-4">
        <label>Carrera</label>
        <select class="form-select" @bind="modelo.Carrera">
            <option value="">-- Seleccione --</option>
            <option value="Ingenieria en Sistemas">Ingenieria en Sistemas</option>
            <option value="Ingenieria en Software">Ingenieria en Software</option>
            <option value="Administracion de Empresas">Administracion de Empresas</option>
            <option value="Contaduria">Contaduria</option>
        </select>
    </div>

    <div class="col-md-4">
        <label>Nivel</label>
        <select class="form-select" @bind="modelo.Nivel">
            <option value="">-- Seleccione --</option>
            <option value="Tecnico">Tecnico</option>
            <option value="Pregrado">Pregrado</option>
            <option value="Posgrado">Posgrado</option>
        </select>
    </div>

    <div class="col-md-4">
        <label>Promedio</label>
        <input type="number" step="0.1" class="form-control" @bind="modelo.Promedio" />
    </div>

    <div class="col-md-4">
        <label>Estado</label>
        <select class="form-select" @bind="modelo.Activo">
            <option value="1">Activo</option>
            <option value="0">Inactivo</option>
        </select>
    </div>

</div>

<br />

<div class="text-center">
    <button type="button" class="btn btn-outline-success" @onclick="guardar">
        @(Id > 0 ? "Actualizar" : "Guardar")
    </button>
    <button type="button" class="btn btn-outline-danger" @onclick="regresar">
        <!-- icono de return de boostrap, esta anidado dentro del boton-->
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-return-left" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M14.5 1.5a.5.5 0 0 1 .5.5v4.8a2.5 2.5 0 0 1-2.5 2.5H2.707l3.347 3.346a.5.5 0 0 1-.708.708l-4.2-4.2a.5.5 0 0 1 0-.708l4-4a.5.5 0 1 1 .708.708L2.707 8.3H12.5A1.5 1.5 0 0 0 14 6.8V2a.5.5 0 0 1 .5-.5" />
        </svg>
    </button>
</div>

@code {

    [Parameter] public int Id { get; set; }

    public EstudianteListCLS modelo = new EstudianteListCLS();

    protected override async Task OnInitializedAsync()
    {
        if (Id > 0)
        {
            modelo = await estudianteService.GetById(Id);
        }
    }

    private async Task guardar()
    {
        if (Id > 0)
        {
            await estudianteService.Update(modelo);
            await App.Current.MainPage.DisplayAlert("Éxito", "Estudiante actualizado correctamente.", "OK");
        }
        else
        {
            await estudianteService.Insert(modelo);
            await App.Current.MainPage.DisplayAlert("Éxito", "Estudiante registrado correctamente.", "OK");
        }

        navigationManager.NavigateTo("/estudiante");
    }

    private async Task regresar()
    {
        navigationManager.NavigateTo("/estudiante");
    }

}
